
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for authenticated users
    function isSignedIn() {
      return request.auth != null;
    }

    // By default, deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow any authenticated user to read/write all primary collections.
    // Explicitly allowing 'read' which covers 'get' and 'list'
    match /forklifts/{forkliftId} {
      allow read, write: if isSignedIn();
    }
    match /employees/{employeeId} {
      allow read, write: if isSignedIn();
    }
    match /attendance/{attendanceId} {
      allow read, write: if isSignedIn();
    }
    match /jobCards/{jobCardId} {
      allow read, write: if isSignedIn();
    }
    match /parts/{partId} {
      allow read, write: if isSignedIn();
    }
    match /maintenanceLogs/{maintenanceLogId} {
      allow read, write: if isSignedIn();
    }
    match /companies/{companyId} {
      allow read, write: if isSignedIn();
    }
    match /invoices/{invoiceId} {
      allow read, write: if isSignedIn();
    }
     match /payments/{paymentId} {
      allow read, write: if isSignedIn();
    }
    match /companySettings/{docId} {
      allow read, write: if isSignedIn();
    }
    match /monthlyRepairs/{monthId} {
      allow read, write: if isSignedIn();
    }
    match /notes/{noteId} {
      allow read, write: if isSignedIn();
    }
    match /salaries/{salaryId} {
      allow read, write: if isSignedIn();
    }

    // Allow users to access their bank accounts sub-collection
    match /companySettings/{docId}/bankAccounts/{accountId} {
      allow read, write: if isSignedIn();
    }
  }
}
