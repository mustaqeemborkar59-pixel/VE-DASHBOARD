{
  "entities": {
    "ServiceRequest": {
      "title": "ServiceRequest",
      "type": "object",
      "description": "Represents a service request for forklift maintenance.",
      "properties": {
        "forkliftId": {
          "type": "string",
          "description": "Reference to the Forklift."
        },
        "requestDate": {
          "type": "string",
          "description": "Date the service request was submitted.",
          "format": "date-time"
        },
        "issueDescription": {
          "type": "string",
          "description": "Description of the issue reported."
        },
        "status": {
          "type": "string",
          "description": "Current status of the service request (e.g., Open, Assigned, In Progress, Completed)."
        },
        "assignedTechnicianId": {
          "type": "string",
          "description": "Reference to the Technician assigned to the request."
        }
      },
      "required": [
        "forkliftId",
        "requestDate",
        "issueDescription",
        "status"
      ]
    },
    "Forklift": {
      "title": "Forklift",
      "type": "object",
      "description": "Represents a forklift in the workshop.",
      "properties": {
        "serialNumber": {
          "type": "string",
          "description": "Serial number of the forklift."
        },
        "make": {
          "type": "string",
          "description": "Make of the forklift (e.g., Toyota, Hyster)."
        },
        "model": {
          "type": "string",
          "description": "Model of the forklift."
        },
        "year": {
          "type": "number",
          "description": "Manufacturing year of the forklift."
        },
        "capacity": {
          "type": "string",
          "description": "Lifting capacity of the forklift (e.g., '5000 lbs')."
        }
      },
      "required": [
        "serialNumber",
        "make",
        "model",
        "year"
      ]
    },
    "Technician": {
      "title": "Technician",
      "type": "object",
      "description": "Represents a technician in the workshop.",
      "properties": {
        "firstName": {
          "type": "string",
          "description": "First name of the technician."
        },
        "lastName": {
          "type": "string",
          "description": "Last name of the technician."
        },
        "specialization": {
          "type": "string",
          "description": "Area of specialization for the technician (e.g., Electrical, Mechanical)."
        },
        "availability": {
          "type": "boolean",
          "description": "Indicates if the technician is currently available for assignment."
        }
      },
      "required": [
        "firstName",
        "lastName",
        "availability"
      ]
    },
    "JobCard": {
      "title": "JobCard",
      "type": "object",
      "description": "Represents a job card for a service request.",
      "properties": {
        "serviceRequestId": {
          "type": "string",
          "description": "Reference to the ServiceRequest."
        },
        "creationDate": {
          "type": "string",
          "description": "Date the job card was created.",
          "format": "date-time"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the work to be done."
        },
        "technicianNotes": {
          "type": "string",
          "description": "Notes added by the assigned technician."
        },
        "completionDate": {
          "type": "string",
          "description": "Date the job was completed.",
          "format": "date-time"
        }
      },
      "required": [
        "serviceRequestId",
        "creationDate",
        "description"
      ]
    },
    "Part": {
      "title": "Part",
      "type": "object",
      "description": "Represents a part in the inventory.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the part."
        },
        "description": {
          "type": "string",
          "description": "Description of the part."
        },
        "quantity": {
          "type": "number",
          "description": "Quantity of the part in stock."
        },
        "unitPrice": {
          "type": "number",
          "description": "Unit price of the part."
        }
      },
      "required": [
        "name",
        "quantity",
        "unitPrice"
      ]
    },
    "MaintenanceLog": {
      "title": "MaintenanceLog",
      "type": "object",
      "description": "Represents a log of maintenance activities performed on a forklift.",
      "properties": {
        "forkliftId": {
          "type": "string",
          "description": "Reference to the Forklift."
        },
        "jobCardId": {
          "type": "string",
          "description": "Reference to the JobCard."
        },
        "date": {
          "type": "string",
          "description": "Date the maintenance was performed.",
          "format": "date-time"
        },
        "description": {
          "type": "string",
          "description": "Description of the maintenance performed."
        },
        "partsUsed": {
          "type": "array",
          "description": "References to Parts used during the maintenance.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "forkliftId",
        "jobCardId",
        "date",
        "description"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/forklifts/{forkliftId}": {
      "schema": {
        "$ref": "#/entities/Forklift"
      },
      "description": "Stores details for each forklift."
    },
    "/technicians/{technicianId}": {
      "schema": {
        "$ref": "#/entities/Technician"
      },
      "description": "Stores profiles for each technician."
    },
    "/serviceRequests/{serviceRequestId}": {
      "schema": {
        "$ref": "#/entities/ServiceRequest"
      },
      "description": "Stores all service requests for the workshop."
    },
    "/jobCards/{jobCardId}": {
      "schema": {
        "$ref": "#/entities/JobCard"
      },
      "description": "Stores job cards for service requests."
    },
    "/parts/{partId}": {
      "schema": {
        "$ref": "#/entities/Part"
      },
      "description": "Stores inventory of parts."
    },
    "/maintenanceLogs/{maintenanceLogId}": {
      "schema": {
        "$ref": "#/entities/MaintenanceLog"
      },
      "description": "Stores maintenance logs for forklifts."
    }
  }
}
