
{
  "entities": {
    "Forklift": {
      "title": "Forklift",
      "type": "object",
      "description": "Represents a forklift in the workshop.",
      "properties": {
        "serialNumber": {
          "type": "string",
          "description": "Serial number of the forklift."
        },
        "make": {
          "type": "string",
          "description": "Make of the forklift (e.g., Toyota, Hyster)."
        },
        "model": {
          "type": "string",
          "description": "Model of the forklift."
        },
        "year": {
          "type": "number",
          "description": "Manufacturing year of the forklift."
        },
        "srNumber": {
          "type": "number",
          "description": "The serial number for ordering."
        },
        "capacity": {
          "type": "string",
          "description": "Lifting capacity of the forklift (e.g., '5000 lbs')."
        },
        "equipmentType": {
          "type": "string",
          "description": "The type of equipment (e.g., Reach Truck, Pallet Jack)."
        },
        "voltage": {
          "type": "string",
          "description": "Voltage of the forklift's battery (e.g., '36V', '48V')."
        },
        "mastHeight": {
          "type": "string",
          "description": "The mast height of the forklift (e.g., '189 inches')."
        },
        "locationType": {
          "type": "string",
          "enum": [
            "Workshop",
            "On-Site",
            "Not Confirm"
          ],
          "description": "Current location of the forklift."
        },
        "locationAssignmentDate": {
          "type": "string",
          "format": "date-time",
          "description": "The date when the current location was assigned."
        },
        "siteCompany": {
          "type": "string",
          "description": "Company name for the site location."
        },
        "siteArea": {
          "type": "string",
          "description": "Geographical area or locality of the site."
        },
        "siteContactPerson": {
          "type": "string",
          "description": "Name of the contact person at the site."
        },
        "siteContactNumber": {
          "type": "string",
          "description": "Contact number of the person at the site."
        },
        "remarks": {
          "type": "string",
          "description": "Extra remarks or notes about the forklift."
        },
        "poPiNumber": {
          "type": "string",
          "description": "PO/PI Number for the forklift."
        }
      },
      "required": [
        "serialNumber",
        "make",
        "model",
        "year",
        "locationType"
      ]
    },
    "Employee": {
      "title": "Employee",
      "type": "object",
      "description": "Represents an employee in the workshop.",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "Full name of the employee."
        },
        "specialization": {
          "type": "string",
          "description": "Area of specialization or role for the employee (e.g., Electrical, Mechanical, Worker)."
        },
        "contactNumber": {
          "type": "string",
          "description": "Contact number of the employee."
        },
        "workLocation": {
          "type": "string",
          "description": "Current work location of the employee (e.g., Workshop, On-Site)."
        },
        "availability": {
          "type": "boolean",
          "description": "Indicates if the employee is currently available for assignment."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the employee was added."
        }
      },
      "required": [
        "fullName",
        "availability"
      ]
    },
    "JobCard": {
      "title": "JobCard",
      "type": "object",
      "description": "Represents a job card for a service or repair request.",
      "properties": {
        "jobTitle": {
          "type": "string",
          "description": "A short summary of the job."
        },
        "forkliftId": {
          "type": "string",
          "description": "Reference to the Forklift being serviced."
        },
        "companyId": {
          "type": "string",
          "description": "Reference to the client Company."
        },
        "employeeId": {
          "type": "string",
          "description": "Reference to the assigned Employee/Technician."
        },
        "status": {
          "type": "string",
          "enum": [
            "Pending",
            "Assigned",
            "In Progress",
            "Completed",
            "Cancelled"
          ],
          "description": "The current status of the job."
        },
        "creationDate": {
          "type": "string",
          "description": "Date and time the job card was created.",
          "format": "date-time"
        },
        "jobDescription": {
          "type": "string",
          "description": "Detailed description of the problem or work to be done."
        },
        "technicianNotes": {
          "type": "string",
          "description": "Notes and updates from the assigned technician."
        },
        "completionDate": {
          "type": "string",
          "description": "Date the job was completed.",
          "format": "date"
        }
      },
      "required": [
        "jobTitle",
        "forkliftId",
        "companyId",
        "status",
        "creationDate",
        "jobDescription"
      ]
    },
    "Part": {
      "title": "Part",
      "type": "object",
      "description": "Represents a part in the inventory.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the part."
        },
        "description": {
          "type": "string",
          "description": "Description of the part."
        },
        "quantity": {
          "type": "number",
          "description": "Quantity of the part in stock."
        },
        "unitPrice": {
          "type": "number",
          "description": "Unit price of the part."
        }
      },
      "required": [
        "name",
        "quantity",
        "unitPrice"
      ]
    },
    "MaintenanceLog": {
      "title": "MaintenanceLog",
      "type": "object",
      "description": "Represents a log of maintenance activities performed on a forklift.",
      "properties": {
        "forkliftId": {
          "type": "string",
          "description": "Reference to the Forklift."
        },
        "jobCardId": {
          "type": "string",
          "description": "Reference to the JobCard."
        },
        "date": {
          "type": "string",
          "description": "Date the maintenance was performed.",
          "format": "date-time"
        },
        "description": {
          "type": "string",
          "description": "Description of the maintenance performed."
        },
        "partsUsed": {
          "type": "array",
          "description": "References to Parts used during the maintenance.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "forkliftId",
        "jobCardId",
        "date",
        "description"
      ]
    },
    "Company": {
      "title": "Company",
      "description": "Represents a client company.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the company."
        },
        "address": {
          "type": "string",
          "description": "Full address of the company."
        },
        "gstin": {
          "type": "string",
          "description": "GST Identification Number of the company."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "address"
      ]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Represents a tax invoice.",
      "type": "object",
      "properties": {
        "enterprise": {
          "type": "string",
          "enum": ["Vithal", "RV"],
          "description": "The enterprise this invoice belongs to."
        },
        "billNo": {
          "type": "number",
          "description": "The sequential invoice number."
        },
        "billNoSuffix": {
          "type": "string",
          "description": "The suffix for the bill number, e.g., 'MHE'"
        },
        "billDate": {
          "type": "string",
          "format": "date"
        },
        "billingMonth": {
            "type": "string",
            "description": "The billing month for the invoice, in YYYY-MM format."
        },
        "companyId": {
          "type": "string",
          "description": "Reference to the Company being billed."
        },
        "poNumber": {
          "type": "string",
          "description": "Purchase Order number, if any."
        },
        "site": {
          "type": "string",
          "description": "The site or location of the service."
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "particulars": {
                "type": "string"
              },
              "rate": {
                "type": "string"
              },
              "amount": {
                "type": "number"
              }
            },
            "required": [
              "particulars",
              "amount"
            ]
          }
        },
        "netTotal": {
          "type": "number"
        },
        "cgst": {
          "type": "number"
        },
        "sgst": {
          "type": "number"
        },
        "grandTotal": {
          "type": "number"
        },
        "tdsPercentage": {
          "type": "number",
          "description": "Tax Deducted at Source percentage for this invoice."
        },
        "discount": {
            "type": "number",
            "description": "Discount amount to be subtracted from the total."
        },
        "discountType": {
          "type": "string",
          "enum": ["before_gst", "after_gst"],
          "description": "Specifies if the discount is applied before or after GST calculation."
        },
        "advanceReceived": {
            "type": "number",
            "description": "Advance amount already paid by the client."
        },
        "myCompanyDetails": {
          "$ref": "#/entities/CompanySettings",
          "description": "A snapshot of the user's company details at the time of invoice creation."
        },
        "clientCompanyDetails": {
          "$ref": "#/entities/Company",
          "description": "A snapshot of the client company's details at the time of invoice creation."
        },
        "selectedBankAccount": {
          "$ref": "#/entities/BankAccount",
          "description": "A snapshot of the bank account selected for this invoice."
        },
        "documentSettings": {
            "type": "object",
            "description": "Layout and formatting settings for the invoice document.",
            "properties": {
                "pageSize": { "type": "string", "enum": ["A4", "LETTER", "LEGAL"] },
                "pageOrientation": { "type": "string", "enum": ["portrait", "landscape"] },
                "pageMargins": {
                    "type": "object",
                    "properties": {
                        "top": { "type": "number" },
                        "right": { "type": "number" },
                        "bottom": { "type": "number" },
                        "left": { "type": "number" }
                    }
                },
                "pageFontSize": { "type": "number" },
                "addressFontSize": { "type": "number" },
                "tableBodyFontSize": { "type": "number" }
            }
        },
        "downloadOptions": {
          "type": "object",
          "properties": {
            "myCompany": {
              "type": "object",
              "properties": {
                "showGstin": {
                  "type": "boolean"
                },
                "showPan": {
                  "type": "boolean"
                },
                "showBankDetails": {
                  "type": "boolean"
                },
                "showSacCode": {
                  "type": "boolean"
                },
                "showServiceTaxCode": {
                  "type": "boolean"
                }
              }
            },
            "clientCompany": {
              "type": "object",
              "properties": {
                "showGstin": {
                  "type": "boolean"
                }
              }
            },
            "includeSiteInFilename": {
              "type": "boolean"
            }
          }
        },
        "template": {
          "type": "object",
          "properties": {
            "columns": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "label": { "type": "string" },
                  "align": { "type": "string", "enum": ["left", "center", "right"] },
                  "fontSize": { "type": "number", "description": "Font size for the column body in points (pt)." }
                }
              }
            }
          }
        }
      },
      "required": [
        "enterprise",
        "billNo",
        "billDate",
        "companyId",
        "items",
        "grandTotal",
        "myCompanyDetails",
        "clientCompanyDetails"
      ]
    },
    "BankAccount": {
      "title": "BankAccount",
      "description": "Represents one of the user's company's bank accounts.",
      "type": "object",
      "properties": {
        "nickname": {
          "type": "string",
          "description": "A short, memorable name for the account (e.g., 'HDFC Main')."
        },
        "bankName": {
          "type": "string"
        },
        "accountNumber": {
          "type": "string"
        },
        "ifscCode": {
          "type": "string"
        },
        "bankBranch": {
          "type": "string"
        }
      },
      "required": [
        "nickname",
        "bankName",
        "accountNumber",
        "ifscCode"
      ]
    },
    "CompanySettings": {
      "title": "CompanySettings",
      "description": "Represents the details of the user's own company (e.g., Vithal Enterprises).",
      "type": "object",
      "properties": {
        "companyName": {
          "type": "string"
        },
        "pan": {
          "type": "string"
        },
        "gstin": {
          "type": "string"
        },
        "sacCode": {
          "type": "string"
        },
        "serviceTaxCode": {
          "type": "string"
        },
        "contactPerson": {
          "type": "string"
        },
        "contactNumber": {
          "type": "string"
        },
        "nextBillNo": {
          "type": "number"
        },
        "pageSize": {
          "type": "string"
        },
        "pageOrientation": {
          "type": "string"
        },
        "pageMargins": {
          "type": "object",
          "properties": {
            "top": {
              "type": "number"
            },
            "right": {
              "type": "number"
            },
            "bottom": {
              "type": "number"
            },
            "left": {
              "type": "number"
            }
          }
        },
        "pageFontSize": {
          "type": "number"
        },
        "addressFontSize": {
          "type": "number"
        },
        "tableBodyFontSize": {
          "type": "number"
        }
      }
    },
     "Payment": {
      "title": "Payment",
      "description": "Represents a payment received for an invoice.",
      "type": "object",
      "properties": {
        "invoiceId": {
          "type": "string",
          "description": "Reference to the Invoice."
        },
        "companyId": {
          "type": "string",
          "description": "Reference to the Company."
        },
        "paymentDate": {
          "type": "string",
          "format": "date"
        },
        "paymentMode": {
            "type": "string",
            "enum": ["RTGS", "NEFT", "IMPS", "CHEQUE", "CASH"],
            "description": "The mode of payment."
        },
        "chequeDetails": {
            "type": "string",
            "description": "Details like cheque number and date, if applicable."
        },
        "receivedAmount": {
          "type": "number",
          "description": "The amount received in this payment transaction."
        },
        "tdsDeducted": {
          "type": "number",
          "description": "Tax Deducted at Source for this payment."
        },
        "otherDeductions": {
          "type": "number",
          "description": "Any other deductions made by the client."
        },
        "notes": {
          "type": "string",
          "description": "Any notes related to this payment."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "invoiceId",
        "companyId",
        "paymentDate",
        "receivedAmount",
        "paymentMode"
      ]
    },
    "MonthlyRepair": {
      "title": "MonthlyRepair",
      "description": "Represents the total number of repairs in a given month. The document ID is the month.",
      "type": "object",
      "properties": {
        "repairs": {
          "type": "number",
          "description": "The total number of repairs for that month."
        }
      },
      "required": ["repairs"]
    },
    "Note": {
      "title": "Note",
      "description": "Represents a user-created note.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the note."
        },
        "content": {
          "type": "string",
          "description": "The main content of the note."
        },
        "color": {
          "type": "string",
          "description": "Background color for the note card.",
          "enum": ["yellow", "blue", "green", "pink", "purple", "default"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the note was created."
        }
      },
      "required": [
        "content",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/forklifts/{forkliftId}": {
      "schema": {
        "$ref": "#/entities/Forklift"
      },
      "description": "Stores details for each forklift."
    },
    "/employees/{employeeId}": {
      "schema": {
        "$ref": "#/entities/Employee"
      },
      "description": "Stores profiles for each employee."
    },
    "/jobCards/{jobCardId}": {
      "schema": {
        "$ref": "#/entities/JobCard"
      },
      "description": "Stores job cards for service requests."
    },
    "/parts/{partId}": {
      "schema": {
        "$ref": "#/entities/Part"
      },
      "description": "Stores inventory of parts."
    },
    "/maintenanceLogs/{maintenanceLogId}": {
      "schema": {
        "$ref": "#/entities/MaintenanceLog"
      },
      "description": "Stores maintenance logs for forklifts."
    },
    "/companies/{companyId}": {
      "schema": {
        "$ref": "#/entities/Company"
      },
      "description": "Stores client company profiles."
    },
    "/invoices/{invoiceId}": {
      "schema": {
        "$ref": "#/entities/Invoice"
      },
      "description": "Stores all generated invoices."
    },
    "/companySettings/{docId}": {
      "schema": {
        "$ref": "#/entities/CompanySettings"
      },
      "description": "Stores the user's own company details. Should contain one document per enterprise ('vithal', 'rv')."
    },
    "/companySettings/primary/bankAccounts/{accountId}": {
      "schema": {
        "$ref": "#/entities/BankAccount"
      },
      "description": "Stores individual bank accounts for the user's company."
    },
    "/payments/{paymentId}": {
        "schema": {
            "$ref": "#/entities/Payment"
        },
        "description": "Stores all payment records for invoices."
    },
    "/monthlyRepairs/{monthId}": {
      "schema": {
        "$ref": "#/entities/MonthlyRepair"
      },
      "description": "Stores the manually entered count of repairs per month. The document ID is the month in YYYY-MM format."
    },
    "/notes/{noteId}": {
      "schema": {
        "$ref": "#/entities/Note"
      },
      "description": "Stores user-created notes."
    }
  }
}
