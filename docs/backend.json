
{
  "entities": {
    "ServiceRequest": {
      "title": "ServiceRequest",
      "type": "object",
      "description": "Represents a service request for forklift maintenance.",
      "properties": {
        "forkliftId": {
          "type": "string",
          "description": "Reference to the Forklift."
        },
        "requestDate": {
          "type": "string",
          "description": "Date the service request was submitted.",
          "format": "date-time"
        },
        "issueDescription": {
          "type": "string",
          "description": "Description of the issue reported."
        },
        "status": {
          "type": "string",
          "description": "Current status of the service request (e.g., Open, Assigned, In Progress, Completed)."
        },
        "assignedTechnicianId": {
          "type": "string",
          "description": "Reference to the Employee assigned to the request."
        }
      },
      "required": [
        "forkliftId",
        "requestDate",
        "issueDescription",
        "status"
      ]
    },
    "Forklift": {
      "title": "Forklift",
      "type": "object",
      "description": "Represents a forklift in the workshop.",
      "properties": {
        "serialNumber": {
          "type": "string",
          "description": "Serial number of the forklift."
        },
        "make": {
          "type": "string",
          "description": "Make of the forklift (e.g., Toyota, Hyster)."
        },
        "model": {
          "type": "string",
          "description": "Model of the forklift."
        },
        "year": {
          "type": "number",
          "description": "Manufacturing year of the forklift."
        },
        "srNumber": {
          "type": "number",
          "description": "The serial number for ordering."
        },
        "capacity": {
          "type": "string",
          "description": "Lifting capacity of the forklift (e.g., '5000 lbs')."
        },
        "equipmentType": {
          "type": "string",
          "description": "The type of equipment (e.g., Reach Truck, Pallet Jack)."
        },
        "voltage": {
          "type": "string",
          "description": "Voltage of the forklift's battery (e.g., '36V', '48V')."
        },
        "mastHeight": {
          "type": "string",
          "description": "The mast height of the forklift (e.g., '189 inches')."
        },
        "locationType": {
            "type": "string",
            "enum": ["Workshop", "On-Site"],
            "description": "Current location of the forklift."
        },
        "siteCompany": {
            "type": "string",
            "description": "Company name for the site location."
        },
        "siteArea": {
            "type": "string",
            "description": "Geographical area or locality of the site."
        },
        "siteContactPerson": {
            "type": "string",
            "description": "Name of the contact person at the site."
        },
        "siteContactNumber": {
            "type": "string",
            "description": "Contact number of the person at the site."
        },
        "remarks": {
          "type": "string",
          "description": "Extra remarks or notes about the forklift."
        }
      },
      "required": [
        "serialNumber",
        "make",
        "model",
        "year",
        "locationType"
      ]
    },
    "Employee": {
      "title": "Employee",
      "type": "object",
      "description": "Represents an employee in the workshop.",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "Full name of the employee."
        },
        "specialization": {
          "type": "string",
          "description": "Area of specialization or role for the employee (e.g., Electrical, Mechanical, Worker)."
        },
        "contactNumber": {
          "type": "string",
          "description": "Contact number of the employee."
        },
        "workLocation": {
          "type": "string",
          "description": "Current work location of the employee (e.g., Workshop, On-Site)."
        },
        "availability": {
          "type": "boolean",
          "description": "Indicates if the employee is currently available for assignment."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the employee was added."
        }
      },
      "required": [
        "fullName",
        "availability"
      ]
    },
    "JobCard": {
      "title": "JobCard",
      "type": "object",
      "description": "Represents a job card for a service request.",
      "properties": {
        "serviceRequestId": {
          "type": "string",
          "description": "Reference to the ServiceRequest."
        },
        "creationDate": {
          "type": "string",
          "description": "Date the job card was created.",
          "format": "date-time"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the work to be done."
        },
        "technicianNotes": {
          "type": "string",
          "description": "Notes added by the assigned employee."
        },
        "completionDate": {
          "type": "string",
          "description": "Date the job was completed.",
          "format": "date-time"
        }
      },
      "required": [
        "serviceRequestId",
        "creationDate",
        "description"
      ]
    },
    "Part": {
      "title": "Part",
      "type": "object",
      "description": "Represents a part in the inventory.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the part."
        },
        "description": {
          "type": "string",
          "description": "Description of the part."
        },
        "quantity": {
          "type": "number",
          "description": "Quantity of the part in stock."
        },
        "unitPrice": {
          "type": "number",
          "description": "Unit price of the part."
        }
      },
      "required": [
        "name",
        "quantity",
        "unitPrice"
      ]
    },
    "MaintenanceLog": {
      "title": "MaintenanceLog",
      "type": "object",
      "description": "Represents a log of maintenance activities performed on a forklift.",
      "properties": {
        "forkliftId": {
          "type": "string",
          "description": "Reference to the Forklift."
        },
        "jobCardId": {
          "type": "string",
          "description": "Reference to the JobCard."
        },
        "date": {
          "type": "string",
          "description": "Date the maintenance was performed.",
          "format": "date-time"
        },
        "description": {
          "type": "string",
          "description": "Description of the maintenance performed."
        },
        "partsUsed": {
          "type": "array",
          "description": "References to Parts used during the maintenance.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "forkliftId",
        "jobCardId",
        "date",
        "description"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/forklifts/{forkliftId}": {
      "schema": {
        "$ref": "#/entities/Forklift"
      },
      "description": "Stores details for each forklift."
    },
    "/employees/{employeeId}": {
      "schema": {
        "$ref": "#/entities/Employee"
      },
      "description": "Stores profiles for each employee."
    },
    "/serviceRequests/{serviceRequestId}": {
      "schema": {
        "$ref": "#/entities/ServiceRequest"
      },
      "description": "Stores all service requests for the workshop."
    },
    "/jobCards/{jobCardId}": {
      "schema": {
        "$ref": "#/entities/JobCard"
      },
      "description": "Stores job cards for service requests."
    },
    "/parts/{partId}": {
      "schema": {
        "$ref": "#/entities/Part"
      },
      "description": "Stores inventory of parts."
    },
    "/maintenanceLogs/{maintenanceLogId}": {
      "schema": {
        "$ref": "#/entities/MaintenanceLog"
      },
      "description": "Stores maintenance logs for forklifts."
    }
  }
}
